{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/threadsafe-systems/pi-sdlc/skills/sdlc/assets/normative-references.schema.json",
  "title": "pi-sdlc normative reference inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "package", "discovery", "sources"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "package": { "type": "string", "const": "pi-sdlc" },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roots", "exclude"],
      "properties": {
        "roots": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "exclude": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "assertion", "targetKind", "ownership", "required", "resolution", "target", "class"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*(\\.[a-z0-9-]+)+$" },
          "source": { "type": "string", "minLength": 1 },
          "assertion": { "type": "string", "minLength": 1 },
          "targetKind": { "enum": ["file", "command", "facility", "external"] },
          "ownership": { "enum": ["package", "consumer", "external"] },
          "required": { "type": "boolean" },
          "resolution": { "enum": ["package", "consumer", "readiness", "external"] },
          "target": { "type": "string", "minLength": 1 },
          "class": { "enum": ["package-public", "delegated", "runtime-tool", "consumer-integration", "optional-enhancement", "internal"] },
          "verification": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "assertion"],
            "properties": { "source": { "type": "string", "minLength": 1 }, "assertion": { "type": "string", "minLength": 1 } }
          }
        }
      }
    }
  }
}
