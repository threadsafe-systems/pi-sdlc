{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/threadsafe-systems/pi-sdlc/skills/sdlc/schema/task-validation-manifest.schema.json",
  "title": "task-validation-manifest",
  "description": "Per-task validation manifest for the portable validator (PV1). Frozen surface: additive within schemaVersion 1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "buildPlan", "repoRoot", "ownedScenarios", "checks", "categories"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "taskId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 64 },
    "buildPlan": { "type": "string", "minLength": 1 },
    "repoRoot": { "type": "string", "const": "." },
    "ownedScenarios": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9]*[0-9]+$" },
      "uniqueItems": true
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/check" }
    },
    "categories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tests", "static", "scenarios", "standards", "bannedPatterns"],
      "properties": {
        "tests": { "$ref": "#/definitions/commandCategory" },
        "static": { "$ref": "#/definitions/commandCategory" },
        "scenarios": { "$ref": "#/definitions/scenarioCategory" },
        "standards": { "$ref": "#/definitions/commandCategory" },
        "bannedPatterns": { "$ref": "#/definitions/commandCategory" }
      }
    }
  },
  "definitions": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "argv", "evidence"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$", "maxLength": 80 },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[^\\r\\n\\u0000]+$" }
        },
        "timeoutMs": { "type": "integer", "minimum": 1000, "maximum": 600000 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[^\\r\\n]+$", "maxLength": 160 }
        }
      }
    },
    "commandCategory": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicability", "checkIds"],
          "properties": {
            "applicability": { "const": "required" },
            "checkIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicability", "reason"],
          "properties": {
            "applicability": { "const": "n/a" },
            "reason": { "type": "string", "pattern": "^[^\\r\\n]+$", "minLength": 12 }
          }
        }
      ]
    },
    "scenarioCategory": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicability", "evidence"],
          "properties": {
            "applicability": { "const": "required" },
            "evidence": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicability", "reason"],
          "properties": {
            "applicability": { "const": "n/a" },
            "reason": { "type": "string", "pattern": "^[^\\r\\n]+$", "minLength": 12 }
          }
        }
      ]
    }
  }
}
