{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/threadsafe-systems/pi-sdlc/skills/sdlc/schema/sdlc.config.schema.json",
  "title": "sdlc.config.json",
  "description": "Per-project configuration for the sdlc skill. schemaVersion 4: intent vocabulary (review/shape/overrides) with { validate, approve } gate dials, plus the panel roster shape.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "prefix", "labelPrefix", "announce", "review", "shape"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 4,
      "description": "Independent config schema version. Version 4 decomposes the design/code gate dials into { validate, approve } objects."
    },
    "prefix": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Drives the stamped panel agent name <prefix>-<phase-slug>."
    },
    "labelPrefix": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Drives the tracker label vocabulary and the stamped agent description identity."
    },
    "announce": {
      "type": "string",
      "minLength": 1,
      "description": "The start-of-work announce string."
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plans": { "type": "string", "minLength": 1 },
        "specs": { "type": "string", "minLength": 1 },
        "reviews": { "type": "string", "minLength": 1 },
        "agents": { "type": "string", "minLength": 1 }
      }
    },
    "tracker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "board"],
      "properties": {
        "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$", "description": "GitHub owner/name." },
        "board": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "url"],
          "properties": {
            "number": { "type": "integer", "minimum": 1 },
            "url": { "type": "string", "format": "uri" }
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "Per-phase local workflow hooks (lifecycle phase names + '*'), agent-executed under announce-on-fire discipline. before=block, after=warn.",
      "properties": {
        "brainstorm": { "$ref": "#/definitions/phaseHooks" },
        "plan": { "$ref": "#/definitions/phaseHooks" },
        "spec": { "$ref": "#/definitions/phaseHooks" },
        "build": { "$ref": "#/definitions/phaseHooks" },
        "implement": { "$ref": "#/definitions/phaseHooks" },
        "pr": { "$ref": "#/definitions/phaseHooks" },
        "*": { "$ref": "#/definitions/phaseHooks" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["brainstorm", "design", "code", "tasks", "panelSize", "onShortfall"],
      "description": "Who reviews what, and how strictly. All dials are explicit — v4 never leaves ceremony implicit.",
      "properties": {
        "brainstorm": { "enum": ["human", "off"], "description": "human: you approve the design; off: no brainstorm gate." },
        "design": { "$ref": "#/definitions/gateDial", "description": "The plan+spec gate: { validate: panel|skip, approve: human|agent }." },
        "code": { "$ref": "#/definitions/gateDial", "description": "The PR gate: { validate: panel|skip, approve: human|agent }." },
        "tasks": { "enum": ["subagent", "self", "off"], "description": "Per-task validation: subagent | self | off." },
        "panelSize": { "type": "integer", "minimum": 1, "description": "Default distinct-model floor for review panels." },
        "onShortfall": { "enum": ["proceed", "fail"], "description": "When a panel can't reach its floor: proceed best-effort (surface it) or fail." }
      }
    },
    "shape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["separateSpec", "publishToTracker", "defaultTrack"],
      "description": "The lifecycle's shape for this repo.",
      "properties": {
        "separateSpec": { "type": "boolean", "description": "true: a distinct Spec phase+gate; false: plan and spec merge into one gated artifact." },
        "publishToTracker": {
          "oneOf": [{ "type": "integer", "minimum": 1 }, { "const": "never" }],
          "description": "Build-task count at/above which the tracker publish step fires ('never' disables it)."
        },
        "defaultTrack": { "enum": ["irreversible", "reversible"], "description": "The when-in-doubt track (never 'none')." }
      }
    },
    "overrides": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "Optional per-track dial overrides. Keys are exactly the two lifecycle tracks.",
      "properties": {
        "irreversible": { "$ref": "#/definitions/trackOverride" },
        "reversible": { "$ref": "#/definitions/trackOverride" }
      }
    },
    "panels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phases"],
      "description": "Optional panel roster + floors. Presence is a readiness concern, not structural validity.",
      "properties": {
        "$comment": { "type": "string" },
        "authorDefault": {
          "type": "string",
          "pattern": "^[^/]+/.+$",
          "description": "Fallback author (provider/model) when --author is omitted."
        },
        "phases": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plan_review", "spec_review", "pr_review", "task_validate"],
          "properties": {
            "plan_review": { "$ref": "#/definitions/panelPhase" },
            "spec_review": { "$ref": "#/definitions/panelPhase" },
            "pr_review": { "$ref": "#/definitions/panelPhase" },
            "task_validate": { "$ref": "#/definitions/panelPhase" }
          }
        }
      }
    }
  },
  "definitions": {
    "gateDial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validate", "approve"],
      "description": "A review gate dial. validate: does an adversarial panel run before the artifact is presented? approve: who adjudicates findings and advances the phase? preview is reserved (no effect in v4).",
      "properties": {
        "validate": { "enum": ["panel", "skip"] },
        "approve": { "enum": ["human", "agent"] },
        "preview": { "type": "boolean", "description": "Reserved: accepted but read by nothing in v4." }
      }
    },
    "gateDialOverride": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "A partial gate dial for per-track overrides: each field optional, deep-merged onto the base dial. At least one field required.",
      "properties": {
        "validate": { "enum": ["panel", "skip"] },
        "approve": { "enum": ["human", "agent"] },
        "preview": { "type": "boolean" }
      }
    },
    "trackOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review"],
      "properties": {
        "review": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "description": "Per-track dials. Only design/code/tasks/panelSize are per-track. design/code are partial gate dials, deep-merged onto the base.",
          "properties": {
            "design": { "$ref": "#/definitions/gateDialOverride" },
            "code": { "$ref": "#/definitions/gateDialOverride" },
            "tasks": { "enum": ["subagent", "self", "off"] },
            "panelSize": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "phaseHooks": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "before": { "$ref": "#/definitions/hookList" },
        "after": { "$ref": "#/definitions/hookList" }
      }
    },
    "hookList": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/hookItem" }
    },
    "hookItem": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["run"],
          "properties": { "run": { "type": "string", "pattern": "^[^\\r\\n]+$" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["use", "do"],
          "properties": {
            "use": { "type": "string", "pattern": "^(skill|tool):[a-z][a-z0-9_-]*$" },
            "do": { "type": "string", "pattern": "^[^\\r\\n]+$" }
          }
        }
      ]
    },
    "panelPhase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prefer"],
      "properties": {
        "panelSize": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional per-phase floor override of review.panelSize (distinct-model axis)."
        },
        "prefer": {
          "type": "array",
          "minItems": 1,
          "description": "Ordered provider/model preference strings, each optionally carrying pi's ':<thinking>' suffix.",
          "items": { "type": "string", "pattern": "^[^/]+/.+$" }
        }
      }
    }
  }
}
