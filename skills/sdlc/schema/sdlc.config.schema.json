{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/threadsafe-systems/pi-sdlc/skills/sdlc/schema/sdlc.config.schema.json",
  "title": "sdlc.config.json",
  "description": "Per-project configuration for the sdlc skill. Merged schemaVersion-2 surface: configuration and panel roster shape/types.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "prefix", "labelPrefix", "announce"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2,
      "description": "Independent config schema version. Version 2 is the merged single-file shape."
    },
    "prefix": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Drives the stamped panel agent name <prefix>-<phase-slug>."
    },
    "labelPrefix": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Drives the tracker label vocabulary and the stamped agent description identity."
    },
    "announce": {
      "type": "string",
      "minLength": 1,
      "description": "The start-of-work announce string."
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plans": {
          "type": "string",
          "minLength": 1
        },
        "specs": {
          "type": "string",
          "minLength": 1
        },
        "reviews": {
          "type": "string",
          "minLength": 1
        },
        "agents": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tracker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "board"],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$",
          "description": "GitHub owner/name."
        },
        "board": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "url"],
          "properties": {
            "number": {
              "type": "integer",
              "minimum": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "Per-phase local workflow hooks (lifecycle phase names + '*'), agent-executed under announce-on-fire discipline. before=block, after=warn.",
      "properties": {
        "brainstorm": {
          "$ref": "#/definitions/phaseHooks"
        },
        "plan": {
          "$ref": "#/definitions/phaseHooks"
        },
        "spec": {
          "$ref": "#/definitions/phaseHooks"
        },
        "build": {
          "$ref": "#/definitions/phaseHooks"
        },
        "implement": {
          "$ref": "#/definitions/phaseHooks"
        },
        "pr": {
          "$ref": "#/definitions/phaseHooks"
        },
        "*": {
          "$ref": "#/definitions/phaseHooks"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile"],
      "description": "Opt-in lifecycle scaffolding around the invariant verification kernel. The key `automation` is reserved for future unattended-lane policy (budget, escalation, graduation); nothing may squat on it.",
      "properties": {
        "profile": {
          "enum": ["solo", "standard", "full", "custom"]
        },
        "gates": {
          "$ref": "#/definitions/lifecycleGates"
        },
        "phases": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mergePlanSpec": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "tracker": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "publishThreshold": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "const": "never"
                }
              ],
              "default": 2
            }
          }
        },
        "taskValidation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "enum": ["subagent", "self", "off"],
              "default": "subagent"
            }
          }
        },
        "tracks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultTrack": {
              "enum": ["irreversible", "reversible"],
              "default": "irreversible"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "phases": {
                "required": ["mergePlanSpec"],
                "properties": {
                  "mergePlanSpec": {
                    "const": true
                  }
                }
              }
            },
            "required": ["phases"]
          },
          "then": {
            "properties": {
              "gates": {
                "not": {
                  "required": ["spec_review"]
                }
              }
            }
          }
        }
      ]
    },
    "enforcement": {
      "enum": ["strict", "preference"],
      "default": "preference",
      "description": "Whether panel diversity-floor shortfalls fail or proceed with an advisory."
    },
    "panels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phases"],
      "description": "Optional panel roster. Presence is a readiness concern, not structural validity.",
      "properties": {
        "$comment": {
          "type": "string"
        },
        "authorDefault": {
          "type": "string",
          "pattern": "^[^/]+/.+$",
          "description": "Fallback author (provider/model) when --author is omitted."
        },
        "rules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "excludeAuthorVendor": {
              "type": "boolean"
            }
          }
        },
        "phases": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plan_review", "spec_review", "pr_review", "task_validate"],
          "description": "Exactly the four panel phases; each required when panels is present.",
          "properties": {
            "plan_review": {
              "$ref": "#/definitions/panelPhase"
            },
            "spec_review": {
              "$ref": "#/definitions/panelPhase"
            },
            "pr_review": {
              "$ref": "#/definitions/panelPhase"
            },
            "task_validate": {
              "$ref": "#/definitions/panelPhase"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "gateMode": {
      "enum": ["panel", "advisory", "human", "off"]
    },
    "perTrackMode": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "irreversible": {
          "$ref": "#/definitions/gateMode"
        },
        "reversible": {
          "$ref": "#/definitions/gateMode"
        }
      }
    },
    "reviewGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "oneOf": [
            {
              "$ref": "#/definitions/gateMode"
            },
            {
              "$ref": "#/definitions/perTrackMode"
            }
          ]
        },
        "minPanel": {
          "type": "integer",
          "minimum": 1,
          "default": 2
        }
      }
    },
    "lifecycleGates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brainstorm": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "enum": ["human", "off"]
            }
          }
        },
        "plan_review": {
          "$ref": "#/definitions/reviewGate"
        },
        "spec_review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "oneOf": [
                {
                  "$ref": "#/definitions/gateMode"
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "minProperties": 1,
                  "properties": {
                    "irreversible": {
                      "$ref": "#/definitions/gateMode"
                    }
                  }
                }
              ]
            },
            "minPanel": {
              "type": "integer",
              "minimum": 1,
              "default": 2
            }
          }
        },
        "pr_review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "$ref": "#/definitions/gateMode"
            },
            "minPanel": {
              "type": "integer",
              "minimum": 1,
              "default": 2
            }
          }
        }
      }
    },
    "phaseHooks": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "before": {
          "$ref": "#/definitions/hookList"
        },
        "after": {
          "$ref": "#/definitions/hookList"
        }
      }
    },
    "hookList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/hookItem"
      }
    },
    "hookItem": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["run"],
          "properties": {
            "run": {
              "type": "string",
              "pattern": "^[^\\r\\n]+$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["use", "do"],
          "properties": {
            "use": {
              "type": "string",
              "pattern": "^(skill|tool):[a-z][a-z0-9_-]*$"
            },
            "do": {
              "type": "string",
              "pattern": "^[^\\r\\n]+$"
            }
          }
        }
      ]
    },
    "panelPhase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prefer"],
      "properties": {
        "minVendor": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "prefer": {
          "type": "array",
          "minItems": 1,
          "description": "Ordered provider/model preference strings. Each entry may optionally carry pi's ':<thinking>' suffix. Shape-only validation deliberately permits provider version suffixes.",
          "items": {
            "type": "string",
            "pattern": "^[^/]+/.+$"
          }
        }
      }
    }
  }
}
