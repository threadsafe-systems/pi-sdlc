{
  "schemaVersion": 2,
  "prefix": "acme",
  "labelPrefix": "acme-sdlc",
  "announce": "Using the sdlc skill to drive this change through its lifecycle.",
  "paths": {
    "plans": "docs/plans",
    "specs": "docs/specs",
    "reviews": "docs/reviews",
    "agents": ".pi/agents"
  },
  "tracker": {
    "repo": "acme-inc/widget",
    "board": {
      "number": 7,
      "url": "https://github.com/orgs/acme-inc/projects/7"
    }
  },
  "hooks": {
    "implement": {
      "before": [
        {
          "use": "tool:my_worktree_tool",
          "do": "Create AND enter a worktree for the feature branch so the session's working root moves into it; target all subsequent writes there."
        }
      ]
    },
    "*": {
      "after": [
        {
          "run": "scripts/notify.sh sdlc-phase-done"
        }
      ]
    }
  },
  "lifecycle": {
    "profile": "full",
    "gates": {
      "brainstorm": {
        "mode": "human"
      },
      "plan_review": {
        "mode": {
          "irreversible": "panel",
          "reversible": "human"
        },
        "minPanel": 2
      },
      "spec_review": {
        "mode": {
          "irreversible": "panel"
        },
        "minPanel": 2
      },
      "pr_review": {
        "mode": "panel",
        "minPanel": 2
      }
    },
    "phases": {
      "mergePlanSpec": false
    },
    "tracker": {
      "publishThreshold": 2
    },
    "taskValidation": {
      "mode": "subagent"
    },
    "tracks": {
      "defaultTrack": "irreversible"
    }
  },
  "enforcement": "preference",
  "panels": {
    "$comment": "Example panel preferences; model ids drift and should be reviewed after seeding.",
    "authorDefault": "anthropic/claude-sonnet-4",
    "rules": {
      "excludeAuthorVendor": true
    },
    "phases": {
      "plan_review": {
        "minVendor": 2,
        "prefer": ["openai/gpt-5:high", "deepseek/deepseek-v3", "anthropic/claude-opus-4:high"]
      },
      "spec_review": {
        "minVendor": 2,
        "prefer": ["anthropic/claude-opus-4", "openai/gpt-5", "deepseek/deepseek-v3"]
      },
      "pr_review": {
        "minVendor": 2,
        "prefer": ["anthropic/claude-opus-4", "openai/gpt-5", "deepseek/deepseek-v3", "zai/glm-4"]
      },
      "task_validate": {
        "minVendor": 1,
        "prefer": ["deepseek/deepseek-v3", "anthropic/claude-haiku-4"]
      }
    }
  }
}
