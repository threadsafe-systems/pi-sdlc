{
  "schemaVersion": 3,
  "prefix": "acme",
  "labelPrefix": "acme-sdlc",
  "announce": "Using the sdlc skill to drive this change through its lifecycle.",
  "paths": {
    "plans": "docs/plans",
    "specs": "docs/specs",
    "reviews": "docs/reviews",
    "agents": ".pi/agents"
  },
  "tracker": {
    "repo": "acme-inc/widget",
    "board": {
      "number": 7,
      "url": "https://github.com/orgs/acme-inc/projects/7"
    }
  },
  "hooks": {
    "implement": {
      "before": [
        {
          "use": "tool:my_worktree_tool",
          "do": "Create AND enter a worktree for the feature branch so the session's working root moves into it; target all subsequent writes there."
        }
      ]
    }
  },
  "review": {
    "brainstorm": "human",
    "design": "panel",
    "code": "panel",
    "tasks": "subagent",
    "panelSize": 2,
    "onShortfall": "proceed"
  },
  "shape": {
    "separateSpec": true,
    "publishToTracker": 2,
    "defaultTrack": "irreversible"
  },
  "overrides": {
    "reversible": { "review": { "design": "human" } }
  },
  "panels": {
    "$comment": "Panel roster. Model ids drift; re-check with `pi --list-models`. Entries may carry pi's ':<thinking>' suffix. panelSize is an optional per-phase floor override of review.panelSize (distinct-model axis).",
    "authorDefault": "anthropic/claude-sonnet-4",
    "phases": {
      "plan_review": { "prefer": ["openai/gpt-5:high", "deepseek/deepseek-v3", "anthropic/claude-opus-4:high"] },
      "spec_review": { "prefer": ["anthropic/claude-opus-4", "openai/gpt-5", "deepseek/deepseek-v3"] },
      "pr_review": { "panelSize": 3, "prefer": ["anthropic/claude-opus-4", "openai/gpt-5", "deepseek/deepseek-v3", "zai/glm-4"] },
      "task_validate": { "panelSize": 1, "prefer": ["deepseek/deepseek-v3", "anthropic/claude-haiku-4"] }
    }
  }
}
