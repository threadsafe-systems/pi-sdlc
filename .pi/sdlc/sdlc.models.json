        "moonshotai/kimi-k2.6"
      ]
    },
    "spec_review": {
      "min_panel": 2,
      "prefer": [
        "anthropic/claude-opus-4-8",
        "openai/gpt-5.2",
        "deepseek/deepseek-v4-pro",
        "zai-coding-cn/glm-5.2"
      ]
    },
    "pr_review": {
      "min_panel": 3,
      "prefer": [
        "anthropic/claude-opus-4-8",
        "openai/gpt-5.2",
        "deepseek/deepseek-v4-pro",
        "zai-coding-cn/glm-5.2",
        "moonshotai/kimi-k2.6"
