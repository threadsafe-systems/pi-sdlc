{
  "schemaVersion": 2,
  "prefix": "loom",
  "labelPrefix": "loom-sdlc",
  "announce": "Using loom-sdlc to drive this change through its lifecycle.",
  "paths": {
    "plans": "docs/plans",
    "specs": "docs/specs",
    "reviews": "docs/reviews",
    "agents": ".pi/agents"
  },
  "tracker": {
    "repo": "threadsafe-systems/loom",
    "board": {
      "number": 4,
      "url": "https://github.com/orgs/threadsafe-systems/projects/4"
    }
  },
  "enforcement": "strict",
  "panels": {
    "$comment": "Per-phase model preference for loom-sdlc panels. Panel shape is enforced by each phase's min_panel: the resolver dedupes to one model per vendor, so min_panel is the distinct-vendor floor; plus rules.exclude_author_vendor. This file expresses preference; resolve-panel.sh reconciles it against live credentials. Model ids drift: re-check with dispatch-subagents/scripts/list-models.sh.",
    "authorDefault": "anthropic/claude-fable-5",
    "rules": {
      "excludeAuthorVendor": true
    },
    "phases": {
      "plan_review": {
        "minVendor": 2,
        "prefer": ["openai-codex/gpt-5.5", "deepseek/deepseek-v4-pro", "amazon-bedrock/global.anthropic.claude-opus-4-8", "zai-coding-cn/glm-5.2"]
      },
      "spec_review": {
        "minVendor": 2,
        "prefer": ["amazon-bedrock/global.anthropic.claude-opus-4-8", "openai-codex/gpt-5.5", "deepseek/deepseek-v4-pro", "zai-coding-cn/glm-5.2", "moonshotai/kimi-k2.7-code"]
      },
      "pr_review": {
        "minVendor": 3,
        "prefer": ["amazon-bedrock/global.anthropic.claude-opus-4-8", "openai-codex/gpt-5.5", "deepseek/deepseek-v4-pro", "zai-coding-cn/glm-5.2", "moonshotai/kimi-k2.7-code"]
      },
      "task_validate": {
        "minVendor": 1,
        "prefer": ["deepseek/deepseek-v4-flash", "anthropic/claude-haiku-4-5"]
      }
    }
  }
}
