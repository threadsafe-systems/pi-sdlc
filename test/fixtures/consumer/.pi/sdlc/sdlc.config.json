{
  "schemaVersion": 4,
  "prefix": "loom",
  "labelPrefix": "loom-sdlc",
  "announce": "Using loom-sdlc to drive this change through its lifecycle.",
  "paths": {
    "plans": "docs/plans",
    "specs": "docs/specs",
    "reviews": "docs/reviews",
    "agents": ".pi/agents"
  },
  "tracker": {
    "repo": "threadsafe-systems/loom",
    "board": {
      "number": 4,
      "url": "https://github.com/orgs/threadsafe-systems/projects/4"
    }
  },
  "review": {
    "brainstorm": "human",
    "design": { "validate": "panel", "approve": "human" },
    "code": { "validate": "panel", "approve": "human" },
    "tasks": "subagent",
    "panelSize": 2,
    "onShortfall": "fail"
  },
  "shape": {
    "separateSpec": true,
    "publishToTracker": 2,
    "defaultTrack": "irreversible"
  },
  "panels": {
    "$comment": "Per-phase model preference for loom-sdlc panels. panelSize is the distinct-model floor (model-identity axis); resolve-panel reconciles preference against live credentials. Model ids drift: re-check with dispatch-subagents/scripts/list-models.sh.",
    "authorDefault": "anthropic/claude-fable-5",
    "phases": {
      "plan_review": {
        "panelSize": 2,
        "prefer": ["openai-codex/gpt-5.5", "deepseek/deepseek-v4-pro", "amazon-bedrock/global.anthropic.claude-opus-4-8", "zai-coding-cn/glm-5.2"]
      },
      "spec_review": {
        "panelSize": 2,
        "prefer": ["amazon-bedrock/global.anthropic.claude-opus-4-8", "openai-codex/gpt-5.5", "deepseek/deepseek-v4-pro", "zai-coding-cn/glm-5.2", "moonshotai/kimi-k2.7-code"]
      },
      "pr_review": {
        "panelSize": 3,
        "prefer": ["amazon-bedrock/global.anthropic.claude-opus-4-8", "openai-codex/gpt-5.5", "deepseek/deepseek-v4-pro", "zai-coding-cn/glm-5.2", "moonshotai/kimi-k2.7-code"]
      },
      "task_validate": {
        "panelSize": 1,
        "prefer": ["deepseek/deepseek-v4-flash", "anthropic/claude-haiku-4-5"]
      }
    }
  }
}
